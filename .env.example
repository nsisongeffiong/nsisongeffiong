# Supabase — get these from your Supabase project dashboard
# Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct PostgreSQL connection string for Drizzle migrations
# Settings → Database → Connection string → URI (use the "direct" connection, not pooled)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Pooled connection string for runtime queries (use this in production)
DATABASE_URL_POOLED=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Your site URL — used for RSS feed and Disqus embed URLs
NEXT_PUBLIC_SITE_URL=https://nsisongeffiong.com

# Your Disqus shortname — find this in disqus.com/admin → Settings → General
NEXT_PUBLIC_DISQUS_SHORTNAME=nsisongeffiong
